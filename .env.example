# Ledgerline — environment variables.
#
# Copy this file to `.env.local` and fill in real values as you sign up for
# each service (see context/how/cloud-accounts-checklist.md).
# `.env.local` is gitignored; never commit it.

# ---------- Oracle Cloud (production k3s cluster) ----------
# Optional during the build phase; cloud deploy is deferred (ADR-0002).
# Local k3d cluster is the active dev/test target. Fill these in only when
# you stand up a real cloud cluster for a live recruiter demo.
ORACLE_INSTANCE_IP=
ORACLE_SSH_KEY_PATH=

# ---------- Supabase (Postgres + pgvector) ----------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# ---------- Vercel (frontend hosting) ----------
VERCEL_TOKEN=

# ---------- Cloudflare (Workers + R2) ----------
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=ledgerline-statements

# ---------- Resend (transactional email) ----------
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ---------- Sentry (error monitoring) ----------
SENTRY_ORG_SLUG=
SENTRY_AUTH_TOKEN=

# ---------- PostHog EU (analytics) ----------
POSTHOG_API_KEY=
POSTHOG_HOST=https://eu.posthog.com

# ---------- Setu Account Aggregator (Money Tracker / M10) ----------
SETU_CLIENT_ID=
SETU_CLIENT_SECRET=
SETU_PRODUCT_INSTANCE_ID=
SETU_AA_BASE_URL=https://fiu-uat.setu.co

# ---------- Razorpay test mode + e-Invoice IRP (Invoice Hub / M9) ----------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ---------- GitHub (repo + GHCR + Actions) ----------
GITHUB_TOKEN=

# ---------- OpenRouter (LLM, $3 cap) ----------
# Key is shared (Fraan does not own the OpenRouter account); account-side cap
# not available, so the $3 lifetime budget is enforced in our code.
# The $3 lifetime budget is enforced in code by packages/openrouter-client/.
OPENROUTER_API_KEY=
# Hard ceiling enforced by the wrapper. Defaults to 3.00 if unset; lowering
# is fine, raising past 3.00 is gated by the wrapper.
LLM_SPEND_LIMIT_USD=3.00
LLM_SPEND_DAILY_LIMIT_USD=0.50

# ---------- Local dev infrastructure (filled automatically by docker-compose / k3d) ----------
LOCAL_POSTGRES_URL=postgres://ledgerline:ledgerline@localhost:5432/ledgerline
LOCAL_REDIS_URL=redis://localhost:6379
LOCAL_REDPANDA_BROKERS=localhost:19092
