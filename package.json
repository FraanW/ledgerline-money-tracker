{
  "name": "ledgerline-money-tracker",
  "version": "0.0.0",
  "private": true,
  "description": "Money Tracker — a hardcore Java (Spring Boot) backend + Next.js frontend. Never-negative double-entry envelope ledger on a multi-tenant, RLS-isolated Postgres core.",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.2.2",
  "scripts": {
    "build": "pnpm -r --filter \"./apps/**\" --filter \"./packages/**\" build",
    "dev": "pnpm -r --parallel --filter \"./apps/**\" dev",
    "lint": "pnpm -r --filter \"./apps/**\" --filter \"./packages/**\" lint",
    "test": "pnpm -r --filter \"./apps/**\" --filter \"./packages/**\" test",
    "typecheck": "pnpm -r --filter \"./apps/**\" --filter \"./packages/**\" typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\" --ignore-path .gitignore",
    "clean": "pnpm -r exec rimraf node_modules dist .next .turbo coverage && rimraf node_modules"
  },
  "devDependencies": {
    "prettier": "^3.4.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.7.0"
  }
}
