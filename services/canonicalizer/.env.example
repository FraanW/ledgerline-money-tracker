# Canonicalizer (M3) configuration. Copy to .env. All knobs have safe defaults.

# ── Embeddings ──────────────────────────────────────────────────────────────
# false -> dependency-light hashing embedder (no model download).
# true  -> sentence-transformers MiniLM (install the `ml` extra first).
CANON_USE_REAL_MODEL=false
CANON_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CANON_EMBEDDING_DIM=384

# ── Confidence gate ─────────────────────────────────────────────────────────
CANON_ACCEPT_THRESHOLD=0.62
CANON_LLM_FLOOR=0.40
CANON_TOP_K=5

# ── LLM fallback (LangGraph + OpenRouter) ───────────────────────────────────
CANON_LLM_ENABLED=false
CANON_OPENROUTER_API_KEY=
CANON_OPENROUTER_MODEL=google/gemini-2.0-flash-001
CANON_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
CANON_LLM_SPEND_CAP_USD=3.0
CANON_LLM_COST_PER_CALL_USD=0.0008

# ── Storage ─────────────────────────────────────────────────────────────────
# Empty -> in-memory vector store. Set to a postgres+pgvector DSN for the
# durable store (apply schema.sql first, then POST /admin/reindex).
CANON_DATABASE_URL=
